#include<stdio.h>
#include<string.h>
int main(){
    int i;
    FILE *fp1, *fp2;
    char str[200], find[200], replace[50];
    fp1 = fopen("input.txt", "r");
    fp2 = fopen("output.txt", "w");
    if(fp1 == NULL || fp2 == NULL)
    {
        printf("file doesnt exist");
        return 1;
    }
    printf("enter a word to find");
    scanf("%s", find);
    printf("enter a word to replace");
    scanf("%s", replace);
    while(fgets(str, sizeof(str), fp1))
    {
        char *pos;
        while((pos = strstr(str, find)) != NULL)
        {
            char temp[200];
            strcpy(temp, pos + strlen(find));
            strcpy(pos, replace);
            strcat(str, temp);
        }
        fputs(str, fp2);
    }
    fclose(fp1);
    fclose(fp2);
    printf("find a file to replace:");
    return 0;
}
