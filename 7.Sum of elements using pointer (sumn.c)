
#include<stdio.h>
#include<stdlib.h>
void main()
{
    int n, i, sum = 0, *ptr;
    printf("enter number of elements");
    scanf("%d", &n);
    ptr = (int *)calloc(n, sizeof(int));
    for(i = 0; i < n; i++){
        printf("enter %d number %d:", i, n);
        scanf("%d", ptr+i);
        sum = sum + (*(ptr+i));
    }
    printf("Sum=%d\n", sum);
    free(ptr);
}
