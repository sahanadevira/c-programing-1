#include<stdio.h>
#include<stdlib.h>
struct threenumber
{
    int n1, n2, n3;
};
int main(){
    struct threenumber num;
    int n;
    FILE *fp;
    printf("enter first number:");
    scanf("%d", &n);
    num.n1 = n;
    num.n2 = 5 * n;
    num.n3 = (5 * n) + 1;
    fp = fopen("cse.bin", "wb");
    if(fp == NULL)
    {
        printf("file doesn't exits\n");
        return 1;
    }
    fwrite(&num, sizeof(struct threenumber), 1, fp);
    printf("data written successfully");
    fclose(fp);
    fp = fopen("cse.bin", "rb");
    if(fp == NULL)
    {
        printf("file not found\n");
        return 1;
    }
    fread(&num, sizeof(struct threenumber), 1, fp);
    printf("valves read from file:\n");
    printf("first number=%d\n", num.n1);
    printf("second number=%d\n", num.n2);
    printf("third number=%d\n", num.n3);
    fclose(fp);
    return 0;
}
